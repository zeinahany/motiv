  <joint
    name="Lid_Joint"
    type="prismatic">
    <origin
      xyz="0.0013003 0.0011755 0.211"
      rpy="3.1416 -1.5708 0" />
    <parent
      link="RobotBody" />
    <child
      link="Lid" />
    <axis
      xyz="0 0 -1" />
    <limit
      lower="0"
      upper="0.18"
      effort="2"
      velocity="2" />
  </joint>

  <!-- ==================== IMU SENSOR ==================== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="RobotBody"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>imu</topic>
      <plugin filename="gz-sim-imu-system"
              name="gz::sim::systems::Imu"/>
    </sensor>
  </gazebo>

  <!-- ==================== ULTRASONIC FRONT ==================== -->
  <link name="ultrasonic_front_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <joint name="ultrasonic_front_joint" type="fixed">
    <parent link="RobotBody"/>
    <child link="ultrasonic_front_link"/>
    <origin xyz="0.20 0.0 0.07" rpy="0 0 0"/>
  </joint>

  <gazebo reference="ultrasonic_front_link">
    <sensor name="ultrasonic_front_sensor" type="gpu_lidar">
      <update_rate>50</update_rate>
      <topic>/ultrasonic/front</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-1.396263</min_angle>
            <max_angle>1.396263</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>0.01</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.08</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

