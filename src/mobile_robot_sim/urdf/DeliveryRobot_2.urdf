      <origin
        xyz="-1.34406336005366E-07 3.9905593718359E-08 -0.0118200674161195"
        rpy="0 0 0" />
      <mass
        value="0.140237419679539" />
      <inertia
        ixx="2.72055362006342E-05"
        ixy="2.75400221469168E-10"
        ixz="6.23456199572729E-12"
        iyy="2.72070295245423E-05"
        iyz="-3.34657496971275E-11"
        izz="2.87493686781454E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mobile_robot_sim/meshes/RL_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 -0.012"
        rpy="0 0 0" />
      <geometry>
        <sphere radius="0.06" />
      </geometry>
    </collision>
  </link>
  <joint
    name="RL_Joint"
    type="continuous">
    <origin
      xyz="-0.1975 -0.23596 -0.025"
      rpy="1.5708 0 0" />
    <parent
      link="RobotBody" />
    <child
      link="RL_Wheel" />
    <axis
      xyz="0 0 -1" />
    <limit
      effort="20"
      velocity="20" />
  </joint>

  <!-- ==================== RR_Wheel ==================== -->
  <link
    name="RR_Wheel">
    <inertial>
      <origin
        xyz="-1.0095125037024E-06 2.69893383642028E-07 0.0117631801590439"
        rpy="0 0 0" />
      <mass
        value="0.140242768860157" />
      <inertia
        ixx="2.72082470884897E-05"
        ixy="-1.21453746959876E-10"
        ixz="8.30766496609559E-11"
        iyy="2.72087892197053E-05"
        iyz="1.8654404533443E-10"
        izz="2.87540011754137E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mobile_robot_sim/meshes/RR_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0.012"
        rpy="0 0 0" />
      <geometry>
        <sphere radius="0.06" />
      </geometry>
    </collision>
  </link>
  <joint
    name="RR_Joint"
    type="continuous">
    <origin
      xyz="-0.1975 0.23634 -0.025"
      rpy="1.5708 0 0" />
    <parent
      link="RobotBody" />
    <child
      link="RR_Wheel" />
    <axis
      xyz="0 0 -1" />
    <limit
      effort="20"
      velocity="20" />
  </joint>

