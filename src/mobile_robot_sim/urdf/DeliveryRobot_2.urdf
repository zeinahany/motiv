  </link>
  <joint
    name="FL_Joint"
    type="continuous">
    <origin
      xyz="0.1975 -0.23596 -0.025"
      rpy="1.5708 0 0" />
    <parent
      link="RobotBody" />
    <child
      link="FL_Wheel" />
    <axis
      xyz="0 0 -1" />
    <limit
      effort="20"
      velocity="20" />
  </joint>

  <!-- ==================== Mecanum Wheel Friction (anisotropic for roller simulation) ==================== -->
  <!-- fdir1 expressed in RobotBody (chassis) frame: high friction along fdir1, zero perpendicular (roller slip) -->
  <!-- Standard mecanum layout: FL/RR wheels have rollers at +45deg, FR/RL at -45deg -->
  <!-- Plugin has FR->left, FL->right due to our +Y=right CAD convention                                      -->
  <gazebo reference="FL_Wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in='RobotBody'>1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="FR_Wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in='RobotBody'>1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="RL_Wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in='RobotBody'>1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="RR_Wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1 gz:expressed_in='RobotBody'>1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <!-- ==================== Lid ==================== -->
  <link
    name="Lid">
    <inertial>
      <origin
        xyz="-0.0137914821400988 -0.0181458602319533 -0.0280728578180717"
        rpy="0 0 0" />
      <mass
        value="0.328922397150776" />
      <inertia
        ixx="0.00404537572099659"
        ixy="2.10933622848677E-09"
        ixz="-2.63417294301499E-10"
        iyy="0.00190327681198023"
        iyz="-1.02868108120959E-06"
        izz="0.002246887155159" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mobile_robot_sim/meshes/Lid.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="-0.014 -0.018 -0.028"
        rpy="0 0 0" />
      <geometry>
        <box size="0.39 0.47 0.02" />
      </geometry>
    </collision>
  </link>
  <joint
    name="Lid_Joint"
    type="prismatic">
    <origin
      xyz="0.0013003 0.0011755 0.211"
      rpy="3.1416 -1.5708 0" />
    <parent
      link="RobotBody" />
    <child
      link="Lid" />
    <axis
      xyz="0 0 -1" />
    <limit
      lower="0"
      upper="0.14"
      effort="100"
      velocity="2" />
        <dynamics damping="0.5" friction="0.1" />
  </joint>

  <!-- ==================== IMU SENSOR ==================== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="RobotBody"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>imu</topic>
      <plugin filename="gz-sim-imu-system"
              name="gz::sim::systems::Imu"/>
    </sensor>
  </gazebo>

  <!-- ==================== ULTRASONIC FRONT ==================== -->
  <link name="ultrasonic_front_link">
    <visual>
      <geometry>
        <cylinder radius="0.005" length="0.005"/>
      </geometry>
      <material name="sensor_mat"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.005" length="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <joint name="ultrasonic_front_joint" type="fixed">
    <parent link="RobotBody"/>
    <child link="ultrasonic_front_link"/>
    <origin xyz="0.25 0.0 0.07" rpy="0 0 0"/>
  </joint>

  <gazebo reference="ultrasonic_front_link">
    <sensor name="ultrasonic_front_sensor" type="gpu_lidar">
      <update_rate>50</update_rate>
      <topic>/ultrasonic/front</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>5</samples>
            <resolution>1</resolution>
            <min_angle>-0.2618</min_angle>
            <max_angle>0.2618</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>0.01</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ==================== ULTRASONIC BACK ==================== -->
