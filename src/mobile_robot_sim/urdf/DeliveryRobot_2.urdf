        rpy="0 0 0" />
      <mass
        value="0.140237535352243" />
      <inertia
        ixx="2.72059827875639E-05"
        ixy="-7.1461410674323E-10"
        ixz="7.14665581005552E-12"
        iyy="2.72066213673703E-05"
        iyz="-2.47020649852739E-11"
        izz="2.87493760574907E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mobile_robot_sim/meshes/FR_Wheel.STL" />
