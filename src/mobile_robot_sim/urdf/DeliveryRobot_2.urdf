  <!-- ==================== FL_Wheel ==================== -->
  <link
    name="FL_Wheel">
    <inertial>
      <origin
        xyz="1.06228346097303E-06 -1.6122280410702E-07 -0.0117631557797424"
        rpy="0 0 0" />
      <mass
        value="0.140242689275222" />
      <inertia
        ixx="2.72084404907458E-05"
        ixy="2.88916204886195E-10"
        ixz="-2.2806907450469E-11"
        iyy="2.72085403616973E-05"
        iyz="-2.07964704173423E-10"
        izz="2.87539407631995E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://mobile_robot_sim/meshes/FL_Wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
