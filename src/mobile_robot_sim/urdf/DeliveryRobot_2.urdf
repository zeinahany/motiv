  <joint name="ultrasonic_back_joint" type="fixed">
    <parent link="RobotBody"/>
    <child link="ultrasonic_back_link"/>
    <origin xyz="-0.25 0.0 0.07" rpy="0 0 3.14159"/>
  </joint>

  <gazebo reference="ultrasonic_back_link">
    <sensor name="ultrasonic_back_sensor" type="gpu_lidar">
      <update_rate>50</update_rate>
      <topic>/ultrasonic/back</topic>
      <ray>
