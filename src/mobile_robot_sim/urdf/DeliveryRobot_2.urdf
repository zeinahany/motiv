  <!-- ==================== Gazebo Native MecanumDrive Plugin ==================== -->
  <gazebo>
    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">
      <!-- Plugin expects +Y=left (ROS convention). Our robot: +Y=right (CAD). Swap L/R to compensate. -->
      <!-- FR_Joint at y=+0.236 maps to plugin's front_left (+Y side) -->
      <!-- FL_Joint at y=-0.236 maps to plugin's front_right (-Y side) -->
      <front_left_joint>FR_Joint</front_left_joint>
      <front_right_joint>FL_Joint</front_right_joint>
      <back_left_joint>RR_Joint</back_left_joint>
      <back_right_joint>RL_Joint</back_right_joint>
      <wheel_separation>0.4723</wheel_separation>
      <wheelbase>0.395</wheelbase>
      <wheel_radius>0.06</wheel_radius>
      <min_acceleration>-5</min_acceleration>
      <max_acceleration>5</max_acceleration>
      <topic>/model/DeliveryRobot_Sim/cmd_vel</topic>
      <odom_topic>/model/DeliveryRobot_Sim/odometry</odom_topic>
      <tf_topic>/model/DeliveryRobot_Sim/tf</tf_topic>
    </plugin>
  </gazebo>


  <!-- ==================== Gazebo Native Lid Position Controller ==================== -->
  <gazebo>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>Lid_Joint</joint_name>
      <topic>/lid_position</topic>
      <p_gain>500</p_gain>
      <i_gain>5.0</i_gain>
      <d_gain>10.0</d_gain>
      <i_max>50</i_max>
      <i_min>-50</i_min>
      <cmd_max>100</cmd_max>
      <cmd_min>-100</cmd_min>
    </plugin>
  </gazebo>

</robot>